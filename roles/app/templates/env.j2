# Portal Admin — Production .env
# Deployed by Ansible — do not edit manually
# Changes will be overwritten on next deploy

APP_NAME="{{ app_name }}"
APP_ENV={{ app_env }}
APP_KEY={{ app_key }}
APP_DEBUG={{ app_debug }}
APP_URL={{ app_url }}

APP_LOCALE={{ app_locale }}
APP_FALLBACK_LOCALE={{ app_locale }}
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS={{ bcrypt_rounds }}

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE={{ db_name }}
DB_USERNAME={{ db_user }}
DB_PASSWORD="{{ db_password }}"

SESSION_DRIVER={{ session_driver }}
SESSION_LIFETIME={{ session_lifetime }}
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION={{ 'reverb' if reverb_enabled else 'log' }}
FILESYSTEM_DISK=local
QUEUE_CONNECTION={{ queue_connection }}

CACHE_STORE={{ cache_store }}

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER={{ mail_mailer }}
MAIL_SCHEME=null
MAIL_HOST={{ mail_host }}
MAIL_PORT={{ mail_port }}
MAIL_USERNAME="{{ mail_username }}"
MAIL_PASSWORD="{{ mail_password }}"
MAIL_FROM_ADDRESS="{{ mail_from_address }}"
MAIL_FROM_NAME="{{ mail_from_name }}"

# Microsoft Graph (email sending via API)
MS_GRAPH_TENANT_ID={{ ms_graph_tenant_id }}
MS_GRAPH_CLIENT_ID={{ ms_graph_client_id }}
MS_GRAPH_CLIENT_SECRET={{ ms_graph_client_secret }}

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="{{ app_name }}"
VITE_REVERB_ENABLED={{ 'true' if reverb_enabled else 'false' }}

{% if reverb_enabled %}
REVERB_APP_ID={{ reverb_app_id }}
REVERB_APP_KEY={{ reverb_app_key }}
REVERB_APP_SECRET={{ reverb_app_secret }}
REVERB_HOST={{ reverb_host }}
REVERB_PORT=443
REVERB_SCHEME={{ reverb_scheme }}

VITE_REVERB_HOST="{{ reverb_host }}"
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME={{ reverb_scheme }}
{% endif %}

AUDIT_ENABLED={{ audit_enabled | lower }}
AUDIT_RETENTION_DAYS={{ audit_retention_days }}

# WHMCS API (client data import)
WHMCS_API_URL={{ whmcs_api_url }}
WHMCS_API_IDENTIFIER={{ whmcs_api_identifier }}
WHMCS_API_SECRET={{ whmcs_api_secret }}

# PowerDNS (reverse DNS management)
POWERDNS_DEFAULT_TTL={{ powerdns_default_ttl }}
POWERDNS_SERVER_ID={{ powerdns_server_id }}
