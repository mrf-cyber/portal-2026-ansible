# Portal Admin — Queue Workers
# Deployed by Ansible — do not edit manually

[program:portal-worker]
process_name=%(program_name)s_%(process_num)02d
command=php {{ app_path }}/artisan queue:work database --queue=emails,pdfs,default --sleep=3 --tries=3 --max-time=3600
autostart=true
autorestart=true
stopasgroup=true
killasgroup=true
user=www-data
numprocs={{ queue_workers }}
redirect_stderr=true
stdout_logfile={{ app_path }}/storage/logs/worker.log
stopwaitsecs=3600
